---
name: <%= ruby_package_name %>

dependencies:
- rust-1-linux

files:
- compile-<%= ruby_version %>.env
- gemrc
- overwrite_shebang.rb
- <%= ruby_blob %>
- <%= rubygems_blob %>
- runtime-<%= ruby_version %>.env
- <%= yaml_blob %>
<%= /^0\.2/ =~ yaml_version ? "- patches/libyaml-#{yaml_version}.patch" : "" %>
